{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "mkdir -p ~/.garminconnect && echo \"$GARMINTOKENS_BASE64\" | base64 -d > ~/.garminconnect/garmin_tokens.json && garmin-mcp --transport sse --port $PORT",
    "restartPolicyType": "ON_FAILURE"
  }
}
